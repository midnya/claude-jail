#!/usr/bin/env python3
"""Launch Claude Code inside the claude-jail Docker sandbox.

    claude-jail [--user NAME] [--config PATH] [docker compose args...]

Leading --user/--config are ours; everything else is forwarded to
`docker compose`. The jail is anchored on the config file (default
./.claude-jail.json, or --config): it lists the `roots` to bind-mount (or
defaults to the config file's own directory). Config parsing lives in the src/
modules (resolve_user, build_prompt, build_env, build_mounts, jail_config),
imported and called in-process; their die() raises SystemExit, so a bad config
aborts before any host state is touched.

The generated mount override is never written to disk: it reaches
`docker compose -f` through an in-memory pipe exposed as /dev/fd/N (the shell's
`<(...)`), so the jail's mount policy can't be read off disk or tampered with.
"""
import argparse
import hashlib
import os
import re
import subprocess
import sys
import threading
from pathlib import Path

SCRIPT_DIR = Path(__file__).resolve().parent
sys.path.insert(0, str(SCRIPT_DIR / "src"))

import build_acl
import build_env
import build_mounts
import build_prompt
import resolve_user
from jail_config import (classify_config, config_dir, container_path, die,
                         parse_roots, read_config, resolved_config)

COMPOSE_FILE = SCRIPT_DIR / "docker-compose.yml"
PROMPT_FILE = SCRIPT_DIR / "system-prompt.md"


def parse_args(argv: "list[str]") -> argparse.Namespace:
    """Parse the invocation.

    Forwards everything after our flags to docker compose untouched. REMAINDER
    stops claiming options at the first non-option token, so a compose
    subcommand (run, build, up, ...) needs nothing special. A compose token that
    *looks* like an option (a global flag such as --progress, or a container
    flag like --rm) must be guarded with a -- separator, or argparse would
    reject it as one of ours; that leading -- is then dropped before forwarding.
    """
    parser = argparse.ArgumentParser(
        allow_abbrev=False,
        description="Launch Claude Code inside the claude-jail Docker sandbox.",
        usage="%(prog)s [--user NAME] [--config PATH] "
              "[--] [docker compose args...]",
    )
    parser.add_argument(
        "-u", "--user", metavar="NAME",
        help='config namespace, overriding the "user" key in the config file '
             "(one of the two must be set); config and credentials persist on "
             "the host in ~/.claude-jail-<name>/ and ~/.claude-jail-<name>.json",
    )
    parser.add_argument(
        "-c", "--config", metavar="PATH",
        help="jail config file (default: ./.claude-jail.json); its roots "
             "(or its own directory) become the jail",
    )
    parser.add_argument(
        "compose_args", nargs=argparse.REMAINDER, metavar="...",
        help="forwarded verbatim to docker compose; put -- before a compose "
             "global flag such as --progress",
    )
    args = parser.parse_args(argv)
    if args.user == "":
        parser.error("--user requires a non-empty value")
    if args.config == "":
        parser.error("--config requires a non-empty value")
    if args.compose_args and args.compose_args[0] == "--":
        args.compose_args = args.compose_args[1:]
    return args


def _feed_pipe(fd: int, data: bytes) -> None:
    try:
        os.write(fd, data)
    except BrokenPipeError:
        pass  # docker closed the override pipe before reading it all
    finally:
        os.close(fd)


def run_compose(base_cmd: "list[str]", compose_args: "list[str]",
                override: str) -> int:
    """Run `docker compose`, feeding the mount override via an in-memory pipe.

    pass_fds keeps the pipe's read end open and CLOEXEC-cleared across the exec,
    so /dev/fd/N is inherited by docker and the compose plugin it spawns (as the
    shell's process-substitution fd was). The writer thread avoids a deadlock if
    the override outgrows the pipe buffer.
    """
    if not override:
        return subprocess.run([*base_cmd, *compose_args]).returncode
    read_fd, write_fd = os.pipe()
    writer = threading.Thread(target=_feed_pipe,
                              args=(write_fd, override.encode()),
                              daemon=True)
    writer.start()
    try:
        cmd = [*base_cmd, "-f", f"/dev/fd/{read_fd}", *compose_args]
        return subprocess.run(cmd, pass_fds=(read_fd,)).returncode
    finally:
        # docker has exited, so closing our read end unblocks the writer with
        # EPIPE at once in the normal case. The bounded join (plus the daemon
        # flag) covers the rare case where a leaked descendant still holds the
        # read end open and the override is larger than the pipe buffer, so we
        # never wait forever on bytes docker no longer needs.
        os.close(read_fd)
        writer.join(timeout=5)


def cleanup_side_containers(base_cmd: "list[str]", project: str) -> None:
    """Tear side containers down, but only when no other live session shares this project.

    Concurrent runs of the same directory share side services (e.g. squid), so reference-count
    the live claude-jail containers and only `down` when none remain; err toward
    leaving it up if the count fails. `down` needs only the base compose file.
    """
    try:
        result = subprocess.run(
            ["docker", "ps", "-q",
             "--filter", f"label=com.docker.compose.project={project}",
             "--filter", "label=com.docker.compose.service=claude"],
            capture_output=True, text=True,
        )
        # Tear down only when the count succeeded and found no live sessions;
        # a failed count leaves the side services up.
        last_session = result.returncode == 0 and not result.stdout.strip()
    except OSError:
        last_session = False
    if last_session:
        subprocess.run([*base_cmd, "down", "--timeout", "0"])


def require_docker_compose() -> None:
    """Abort unless the docker CLI and its v2 compose plugin are both present.

    One call proves both: an OSError means docker itself is absent, a non-zero
    return means the plugin is (we drive `docker compose`, not the legacy
    standalone docker-compose binary).
    """
    try:
        ok = subprocess.run(["docker", "compose", "version"],
                            capture_output=True).returncode == 0
    except OSError:
        die("docker not found on PATH")
    if not ok:
        die("docker compose plugin not found "
            "(the legacy standalone docker-compose binary is not supported)")


# `docker compose` global flags that consume the following token as their value;
# every other token starting with "-" is a valueless global flag. Used to find
# the subcommand even when global flags precede it (e.g. `--progress plain run`).
# It's a terrible solution to a silly problem, but heh.
_COMPOSE_VALUE_FLAGS = frozenset({
    "-f", "--file", "-p", "--project-name", "--profile", "--env-file",
    "--ansi", "--progress", "--project-directory", "--parallel",
})


def compose_subcommand(compose_args: "list[str]") -> "str | None":
    """The docker compose subcommand, skipping any leading global flags."""
    i = 0
    while i < len(compose_args):
        tok = compose_args[i]
        if not tok.startswith("-"):
            return tok
        if tok in _COMPOSE_VALUE_FLAGS:  # spaced `--flag value`: skip its value too
            i += 1
        i += 1
    return None

_LAUNCH_SUBCOMMANDS = frozenset({"run", "up", "create", "start", "restart"})


def jail_identity(config_path: str) -> "tuple[str, str]":
    """Derive the jail id and compose project name from the config file path.

    The config file is the jail's anchor, so its realpath gives a stable
    identity across CWD changes. JAIL_ID slugs the *full* realpath, keeping the
    tmp / squid-logs volume names unique and predictable. The compose project
    name — which docker turns into the container and network names — slugs only
    the config's directory name, so a container reads as `myproject-claude-run-…`
    instead of repeating the whole path. Both fall back to "root" so even a
    config at "/" produces a valid, non-empty name; distinct directories that
    share a basename collide onto one project (accepted, like the JAIL_ID slug).
    """
    real = resolved_config(config_path)
    jail_id = re.sub(r"[^A-Za-z0-9]+", "-", str(real).strip("/")) or "root"
    project = re.sub(r"[^A-Za-z0-9]+", "-", real.parent.name) or "root"
    return jail_id, project.lower()


def egress_id_of(policy_key: str) -> str:
    """A short, stable id for an egress policy, derived from build_acl.policy_key.

    Folded into COMPOSE_PROJECT_NAME so the shared squid side-service is shared
    only among runs with the *same* policy: two concurrent runs in one project
    with different egress configs get separate proxies instead of silently
    sharing whichever one started squid first. policy_key is canonical and
    render-independent, so the id (and thus the proxy's identity) changes only
    when the policy changes, never when the Squid fragment's formatting does.
    """
    return hashlib.sha256(policy_key.encode()).hexdigest()[:8]


def container_workdir(config_path: str) -> str:
    """The container working directory: the config file's own directory, mounted.

    Each jail root at host path D is bound into the container at /workspace{D},
    so the config file's directory lands at /workspace<dir>, opening the agent
    inside the project rather than at the bare /workspace above the mounts.

    This path is used even when the config's directory is not one of the mounted
    roots (docker creates the missing working dir as an empty directory). Falling
    back to a shared /workspace there would hand every such jail the same working
    directory, so anything keyed on it — claude's per-project history/state under
    the shared per-user config — would bleed between unrelated workspaces. The
    config-derived path keeps each workspace distinct.
    """
    return container_path(config_dir(config_path))


def build_jail(user_flag: "str | None",
               config_path: str) -> "tuple[dict, str, list[str]]":
    """Validate the config and assemble the launch environment and mount override.

    Resolves the jail roots from the config (or its own directory), confines the
    system prompt, and masks the active config in whichever root holds it. Runs
    entirely before any host state is touched, so a bad config aborts via die()
    here. Returns (environment, override, seeds): the jail user and compose
    project name live in environment (JAIL_USER / COMPOSE_PROJECT_NAME); seeds
    lists absent config files the caller creates as `{}` before a container launch.
    """
    data = read_config(config_path)
    jail_user = resolve_user.resolve(data, user_flag, config_path)
    roots = parse_roots(data, config_path)
    config_class = classify_config(roots, config_path)
    workdir = container_workdir(config_path)
    prompt = build_prompt.merge(PROMPT_FILE.read_text(encoding="utf-8"), data,
                                config_path, roots, config_class is not None,
                                workdir)
    jail_id, project = jail_identity(config_path)
    squid_acl = build_acl.squid_rules(data, config_path)
    egress_id = egress_id_of(build_acl.policy_key(data, config_path))
    environment = {
        "JAIL_ID": jail_id,
        "JAIL_USER": jail_user,
        "JAIL_WORKDIR": workdir,
        # Fold the egress policy into the proxy's identity (project name + its
        # logs volume) so a differing policy never reuses another run's squid.
        "COMPOSE_PROJECT_NAME": f"{project}-{egress_id}",
        "JAIL_EGRESS_ID": egress_id,
        "CLAUDE_APPEND_SYSTEM_PROMPT": prompt,
        "JAIL_SQUID_ACL": squid_acl,
        **build_env.exports(data, config_path),
    }
    override, seeds = build_mounts.override(roots, config_class)
    return environment, override, seeds


def ensure_user_config(home: Path, jail_user: str) -> None:
    """Create the per-user config dir/file on the host if they don't exist."""
    user_dir = home / f".claude-jail-{jail_user}"
    user_file = home / f".claude-jail-{jail_user}.json"
    try:
        user_dir.mkdir(parents=True, exist_ok=True)
        if not user_file.exists():
            user_file.write_text("{}\n")
    except OSError as e:
        die(f"could not create the per-user config in {home}: {e}")


def main() -> None:
    args = parse_args(sys.argv[1:])
    require_docker_compose()
    if not PROMPT_FILE.is_file():
        die(f"base system prompt not found: {PROMPT_FILE}")

    config_path = args.config or os.path.join(os.getcwd(), ".claude-jail.json")
    environment, override, seeds = build_jail(args.user, config_path)

    # Config is valid; now apply the env.
    os.environ.update(environment)

    base_cmd = ["docker", "compose", "-f", str(COMPOSE_FILE)]
    subcommand = compose_subcommand(args.compose_args)
    # Only a subcommand that actually launches the jail container needs the host
    # state the mounts consume (see _LAUNCH_SUBCOMMANDS).
    if subcommand in _LAUNCH_SUBCOMMANDS:
        home_env = os.environ.get("HOME")
        if not home_env:
            die("HOME is not set; cannot locate the per-user config directory")
        ensure_user_config(Path(home_env), environment["JAIL_USER"])
        if override:
            build_mounts.ensure_empty_mask()
        build_mounts.seed_masked_configs(seeds)

    status = run_compose(base_cmd, args.compose_args, override)
    if subcommand == "run":
        cleanup_side_containers(base_cmd, environment["COMPOSE_PROJECT_NAME"])
    sys.exit(status)


if __name__ == "__main__":
    main()
